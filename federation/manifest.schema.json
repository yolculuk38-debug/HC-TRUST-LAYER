{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hc-trust-layer.org/schemas/federation/manifest.schema.json",
  "title": "HC Federation Manifest",
  "description": "Experimental manifest for describing trusted federation nodes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "nodes"],
  "properties": {
    "manifest_version": {"type": "string", "default": "0.1.0-experimental"},
    "generated_at": {"type": "string", "format": "date-time"},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/federation_node"}
    }
  },
  "$defs": {
    "federation_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "endpoint_url", "public_key", "trust_scope", "protocol_version", "verification_capabilities"],
      "properties": {
        "node_id": {"type": "string", "minLength": 3},
        "endpoint_url": {"type": "string", "format": "uri"},
        "public_key": {"type": "string", "description": "Public key placeholder. Real key rotation policy is pending."},
        "trust_scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "protocol_version": {"type": "string"},
        "verification_capabilities": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "status": {"type": "string", "enum": ["active", "degraded", "offline", "unknown"], "default": "unknown"}
      }
    }
  }
}
